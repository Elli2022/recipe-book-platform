{
  "name": "recipe-book-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "migrate:recipes": "node --env-file=.env.local ./scripts/migrate-recipes-to-supabase.mjs",
    "verify:supabase": "node --env-file=.env.local ./scripts/verify-supabase.mjs",
    "seed:marias-kladdkaka": "node --env-file=.env.local ./scripts/seed-marias-kladdkaka.mjs",
    "seed:family-recipes": "node --env-file=.env.local ./scripts/seed-family-recipes.mjs",
    "prepare:jasmina-image": "bash ./scripts/prepare-jasmina-image.sh",
    "update:ellis-lasagne-image": "node --env-file=.env.local ./scripts/update-ellis-lasagne-image.mjs",
    "update:eleonora-spaghetti": "node --env-file=.env.local ./scripts/update-eleonora-spaghetti.mjs",
    "normalize:recipe-images": "node --env-file=.env.local ./scripts/normalize-recipe-images.mjs",
    "restore:embedded-images": "node --env-file=.env.local ./scripts/restore-embedded-recipe-images.mjs",
    "screenshots": "node ./scripts/capture-screenshots.mjs",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.104.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.35",
    "playwright": "^1.60.0",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.1",
    "vite": "^6.3.5",
    "typescript": "^5"
  }
}
